# API + storefront URLs (no trailing slash).
# Vite reads repo root `.env` too — you can set FRONTEND_PATH / BACKEND_PATH there once for both apps.

VITE_BACKEND_PATH=http://localhost:3000
VITE_FRONTEND_PATH=http://localhost:5173

# ── PayPal ────────────────────────────────────────────────────────────────────
# Use your sandbox Client ID for development (found at developer.paypal.com).
# NOTE: PayPal is temporarily disabled at checkout (PAYPAL_ENABLED in CheckoutPage.tsx).
VITE_PAYPAL_CLIENT_ID=AZJlIA44NqKzdilIQKrja0-Y5WwLyMN-Lx02NQqwljx5QcXKP4-0pfyQoNXS7TRT9sn10VR00DxulQO7

# ── WhatsApp checkout ───────────────────────────────────────────────────────────
# Merchant WhatsApp Business number in international format, digits only.
# Sri Lanka example: 94771234567 (country code 94 + number without leading 0).
VITE_WHATSAPP_NUMBER=94770000000

# Or use shared names (loaded from root `.env` via vite.config):
# BACKEND_PATH=http://localhost:3000
# FRONTEND_PATH=http://localhost:5173

# Legacy alias (still supported):
# VITE_API_URL=http://localhost:3000
