# Shared URLs for Throttle LK (copy to `.env` at this folder root, or set in Backend/.env and Frontend/.env)

# Storefront (Vite dev server or production site) — used for CORS on the API
FRONTEND_PATH=http://localhost:5173

# NestJS API base URL (no trailing slash) — used by the React app for all API calls
BACKEND_PATH=http://localhost:3000
