# ── Production backend config ─────────────────────────────────────────────────
# Copy this to `.env` on the SERVER that hosts the API and fill in real secrets.
# Do NOT commit the real `.env` (it is gitignored).

PORT=3000

# Public URLs (no trailing slash).
# FRONTEND_PATH doubles as the allowed CORS origin for the storefront.
FRONTEND_PATH=https://throttlelk.online
BACKEND_PATH=https://api.throttlelk.online

# Allowed browser origins for the API (comma-separated). Include the storefront.
CORS_ORIGIN=https://throttlelk.online

# ── Database ──────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=throttlelk
# Use migrations in production instead of auto-sync.
DB_SYNC=false

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=8h
ADMIN_USERNAME=admin
# Use a bcrypt hash in production (node -e "require('bcrypt').hash('yourpassword',10).then(console.log)")
ADMIN_PASSWORD_HASH=

# ── PayPal ────────────────────────────────────────────────────────────────────
PAYPAL_MODE=live
PAYPAL_CLIENT_ID=your_live_client_id
PAYPAL_CLIENT_SECRET=your_live_client_secret
LKR_PER_USD=320

# ── Cloudinary ────────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=yhaikawr
CLOUDINARY_API_KEY=your_key
CLOUDINARY_API_SECRET=your_secret
CLOUDINARY_FOLDER=throttlelk
